# Shared compose interpolation values.

COMPOSE_PROJECT_NAME=obsura

# Local or staging can use a release tag. Production should use a digest:
# OBSURA_API_IMAGE=ghcr.io/obsura/obsura-api@sha256:replace-with-published-digest
OBSURA_API_IMAGE=ghcr.io/obsura/obsura-api:replace-with-release-tag
POSTGRES_IMAGE=postgres:17-alpine

OBSURA_API_BIND_ADDRESS=127.0.0.1
OBSURA_API_HOST_PORT=8000

OBSURA_STORAGE_VOLUME=obsura-storage
OBSURA_POSTGRES_VOLUME=obsura-postgres
POSTGRES_DATA_PATH=/var/lib/postgresql/data/pgdata

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

BACKUP_ROOT=./backups
