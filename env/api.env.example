# Non-secret obsura-api runtime settings.
# OBSURA_ENV and OBSURA_STORAGE_ROOT are set by the compose files.
# DATABASE_URL is assembled by compose from postgres settings.

OBSURA_API_V1_PREFIX=/api/v1
OBSURA_MEDIA_MOUNT_PATH=/media
OBSURA_AUTO_CREATE_SCHEMA=true
OBSURA_RETAIN_SOURCE_CONTENT_BY_DEFAULT=false
OBSURA_IMAGE_OUTPUT_FORMAT=PNG
