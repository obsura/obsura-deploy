# Non-secret obsura-api runtime settings.
# OBSURA_ENV, OBSURA_STORAGE_ROOT, and DATABASE_URL are set by the compose files.

# API base path used by the container healthcheck and most reverse proxy rules.
OBSURA_API_V1_PREFIX=/api/v1

# Writable media mount path exposed by the application.
OBSURA_MEDIA_MOUNT_PATH=/media

# Current deployments expect the API to initialize schema objects when needed.
# Revisit this when obsura-api publishes a separate migration workflow.
OBSURA_AUTO_CREATE_SCHEMA=true

# Default privacy posture for uploaded source content.
OBSURA_RETAIN_SOURCE_CONTENT_BY_DEFAULT=false

# Output image format for generated assets.
OBSURA_IMAGE_OUTPUT_FORMAT=PNG
