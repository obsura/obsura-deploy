# PostgreSQL container settings consumed by both Docker Compose and helper tooling.
# Keep these aligned with the DATABASE_URL assembled in the compose files.

POSTGRES_DB=obsura
POSTGRES_USER=obsura
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_INITDB_ARGS="--auth-host=scram-sha-256 --auth-local=scram-sha-256"
