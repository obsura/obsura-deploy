# PostgreSQL container settings.
# Keep POSTGRES_DB, POSTGRES_USER, and POSTGRES_PASSWORD aligned with the
# DATABASE_URL assembled for obsura-api by the compose files.

POSTGRES_DB=obsura
POSTGRES_USER=obsura
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_INITDB_ARGS="--auth-host=scram-sha-256 --auth-local=scram-sha-256"
