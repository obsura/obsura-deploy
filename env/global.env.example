# Shared Docker Compose interpolation values for both local and production usage.
# Format: KEY=value. Keep these files shell-safe because the helper scripts parse them directly.

COMPOSE_PROJECT_NAME=obsura

# Local evaluation can use a release tag.
# Production should prefer a published digest from the release you actually validated.
OBSURA_API_IMAGE=ghcr.io/obsura/obsura-api:replace-with-release-tag
# OBSURA_API_IMAGE=ghcr.io/obsura/obsura-api@sha256:replace-with-published-digest

# PostgreSQL is consumed as a published upstream runtime dependency.
POSTGRES_IMAGE=postgres:17-alpine

# Bind the API to localhost by default so a reverse proxy can be the only public edge.
OBSURA_API_BIND_ADDRESS=127.0.0.1
OBSURA_API_HOST_PORT=8000

# Docker named volumes used by the compose files.
OBSURA_STORAGE_VOLUME=obsura-storage
OBSURA_POSTGRES_VOLUME=obsura-postgres
POSTGRES_DATA_PATH=/var/lib/postgresql/data/pgdata

# Volume initialization tries to discover the runtime user inside the image.
# Only change these values if the published image contract changes.
OBSURA_RUNTIME_USER=obsura
OBSURA_RUNTIME_UID=1000
OBSURA_RUNTIME_GID=1000

# Container log rotation for the json-file logging driver.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# Default relative backup location used by the backup helpers.
BACKUP_ROOT=./backups
